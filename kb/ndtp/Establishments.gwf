        <node type="node/const/perm/general" idtf="" shapeColor="0" id="123530265963312" parent="0" x="-753.414" y="1051.23" haveBus="false" idtf_pos="0">
            <content type="1" mime_type="content/term" content_visibility="true" file_name=""><![CDATA[БГМУ]]></content>
        </node>
        <node type="node/const/perm/general" idtf="" shapeColor="0" id="123530265963104" parent="0" x="-1034.51" y="1221.95" haveBus="false" idtf_pos="0">
            <content type="1" mime_type="content/term" content_visibility="true" file_name=""><![CDATA[Белорусский государственный медицинский университет (БГМУ) — ведущий медицинский вуз Беларуси, основанный в 1930 году. Университет включает 7 факультетов и 3 института, предлагая обучение по различным медицинским специальностям. В БГМУ обучаются более 7000 студентов, включая свыше 800 иностранных граждан из более чем 60 стран.]]></content>
        </node>
        <node type="node/const/perm/general" idtf="" shapeColor="0" id="123530265962896" parent="0" x="179.653" y="1041.87" haveBus="false" idtf_pos="0">
            <content type="1" mime_type="content/term" content_visibility="true" file_name=""><![CDATA[ БГУ]]></content>
        </node>
        <node type="node/const/perm/general" idtf="" shapeColor="0" id="123530265962688" parent="0" x="-108.935" y="1214.42" haveBus="false" idtf_pos="0">
            <content type="1" mime_type="content/term" content_visibility="true" file_name=""><![CDATA[Белорусский государственный университет (БГУ) — ведущий вуз Беларуси, основанный в 1921 году. Университет предлагает обучение по 81 специальности первой ступени высшего образования и 65 специальностям второй ступени. БГУ входит в 2% лучших вузов мира и активно участвует в международных научных проектах.]]></content>
        </node>
        <node type="node/const/perm/general" idtf="" shapeColor="0" id="123530265962480" parent="0" x="-742.061" y="1446.29" haveBus="false" idtf_pos="0">
            <content type="1" mime_type="content/term" content_visibility="true" file_name=""><![CDATA[БарГУ]]></content>
        </node>
        <node type="node/const/perm/general" idtf="" shapeColor="0" id="123530265962272" parent="0" x="-1023.16" y="1607.24" haveBus="false" idtf_pos="0">
            <content type="1" mime_type="content/term" content_visibility="true" file_name=""><![CDATA[Барановичский государственный университет (БарГУ) — высшее учебное заведение в городе Барановичи, основанное в 2004 году. Университет включает четыре факультета: инженерный, лингвистический, педагогики и психологии, а также экономики и права. В БарГУ обучается более 5500 студентов, обучение которых обеспечивают свыше 360 преподавателей. Ректором университета с 2021 года является Александр Николаевич Унсович.]]></content>
        </node>
        <node type="node/const/perm/general" idtf="" shapeColor="193" id="123530265962064" parent="0" x="175.056" y="1465.22" haveBus="false" idtf_pos="0">
            <content type="1" mime_type="content/term" content_visibility="true" file_name=""><![CDATA[БГАИ]]></content>
        </node>
        <node type="node/const/perm/general" idtf="" shapeColor="193" id="123530265961648" parent="0" x="-108.745" y="1618.05" haveBus="false" idtf_pos="0">
            <content type="1" mime_type="content/term" content_visibility="true" file_name=""><![CDATA[Белорусская государственная академия искусств (БГАИ) — ведущий вуз Беларуси в сфере театрального, изобразительного, декоративно-прикладного, кино- и телеискусства, а также дизайна. Основанная в 1945 году, академия включает четыре факультета: театральный, экранных искусств, художественный, а также дизайна и декоративно-прикладного искусства.]]></content>
        </node>
