            },
            {
                "name": "В области науки",
                "id": 1
            },
            {
                "name": "В области искусства",
                "id": 2
            }
        \]
    },
    {
        "display_name": "Кем бы вы скорее согласились стать?",
        "answers": \[
            {
                "name": "Главным механиком",
                "id": 0
            },
            {
                "name": "Начальником экспедиции",
                "id": 1
            },
            {
                "name": "Главным бухгалтером",
                "id": 2
            }
        \]
    },
    {
        "display_name": "Что, по вашему мнению, определяет будущее людей?",
        "answers": \[
            {
                "name": "Взаимопонимание между людьми",
                "id": 0
            },
            {
                "name": "Научные открытия",
                "id": 1
            },
            {
                "name": "Развитие производства",
                "id": 2
            }
