        <node type="node/const/perm/general" idtf="" shapeColor="0" id="123530261010288" parent="0" x="325.318" y="501.513" haveBus="false" idtf_pos="0">
            <content type="1" mime_type="content/term" content_visibility="true" file_name=""><![CDATA[Белорусский государственный педагогический университет — один из старейших вузов страны, ведущий центр педагогического образования, основанный в 1914 году. Университет готовит специалистов для всех уровней системы образования и активно развивает научные исследования в педагогике и психологии. В составе — широкий спектр факультетов: от филологического и исторического до естествознания, начального и дошкольного образования, эстетического и физического воспитания.]]></content>
        </node>
